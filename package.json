{
  "name": "vibeats",
  "module": "server.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot server.js",
    "start": "bun run server.js",
    "seed": "bun run seed.js",
    "build:css": "bunx @tailwindcss/cli -i ./assets/css/tailwind.css -o ./assets/css/styles.css --minify",
    "watch:css": "bunx @tailwindcss/cli -i ./assets/css/tailwind.css -o ./assets/css/styles.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "@types/bun": "latest",
    "tailwindcss": "^4.1.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@types/pdfkit": "^0.17.5",
    "ejs": "^3.1.10",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "yaml": "^2.8.1"
  }
}
