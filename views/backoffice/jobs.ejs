<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <link rel="stylesheet" href="/assets/css/style.css" />
    <script type='module' src='/theme.js'></script>
  </head>
  <body class="min-h-screen bg-(--color-bg) text-(--color-text) antialiased">
    <%- include('../partials/navbar') %>
    <header class="mx-auto max-w-5xl px-6 py-10">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <h1 class="text-3xl font-semibold tracking-tight">Jobs</h1>
          <p class="mt-2 text-sm text-(--color-muted)"><%= companyName %> · Manage published and draft roles</p>
        </div>
        <a
          href="/backoffice/jobs/new"
          class="inline-flex items-center rounded-xl bg-(--color-accent) px-4 py-2 text-sm font-medium text-white"
        >
          Create Job
        </a>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-6 pb-12">
      <section class="rounded-2xl border border-(--color-border) bg-white p-5 shadow-sm">
        <% if (!jobs.length) { %>
          <p class="text-sm text-(--color-muted)">No jobs yet. Create your first posting.</p>
        <% } else { %>
          <ul class="divide-y divide-(--color-border)">
            <% jobs.forEach(function(job) { %>
              <li class="py-4 flex flex-wrap items-center justify-between gap-3">
                <div>
                  <h2 class="text-base font-semibold"><%= job.title %></h2>
                  <p class="mt-1 text-sm text-(--color-muted)"><%= job.location || 'Location TBD' %> · <%= job.employmentType || 'Employment type TBD' %></p>
                  <p class="mt-1 text-xs text-(--color-muted)">Questions: <%= job.questionCount || 0 %></p>
                </div>
                <div class="flex items-center gap-3">
                  <span class="rounded-full bg-(--color-chip-bg) px-2.5 py-1 text-xs font-medium text-(--color-chip-text)"><%= job.status %></span>
                  <a href="/backoffice/jobs/<%= job.id %>" class="text-sm font-medium text-(--color-accent)">Edit</a>
                </div>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </section>
    </main>
  </body>
</html>
