<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <link rel="stylesheet" href="/assets/css/style.css" />
  </head>
  <body class="min-h-screen bg-(--color-bg) text-(--color-text) antialiased">
    <header class="mx-auto max-w-5xl px-6 py-10">
      <div>
        <a href="/jobs" class="text-sm text-(--color-accent)">← Back to jobs</a>
        <h1 class="mt-2 text-3xl font-semibold tracking-tight"><%= job.title %></h1>
        <p class="mt-2 text-sm text-(--color-muted)"><%= job.location || 'Location TBD' %> · <%= job.employmentType || 'Employment type TBD' %></p>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-6 pb-12 grid gap-6">
      <section class="rounded-2xl border border-(--color-border) bg-white p-5 shadow-sm grid gap-4">
        <% if (job.intro) { %>
          <div>
            <h2 class="text-sm font-medium uppercase tracking-wide text-(--color-muted)">Intro</h2>
            <p class="mt-2 text-sm leading-relaxed"><%= job.intro %></p>
          </div>
        <% } %>

        <% if (job.description) { %>
          <div>
            <h2 class="text-sm font-medium uppercase tracking-wide text-(--color-muted)">Description</h2>
            <p class="mt-2 text-sm leading-relaxed"><%= job.description %></p>
          </div>
        <% } %>

        <% if (job.requiredQualifications) { %>
          <div>
            <h2 class="text-sm font-medium uppercase tracking-wide text-(--color-muted)">Required Qualifications</h2>
            <p class="mt-2 text-sm leading-relaxed whitespace-pre-wrap"><%= job.requiredQualifications %></p>
          </div>
        <% } %>

        <% if (job.recommendedQualifications) { %>
          <div>
            <h2 class="text-sm font-medium uppercase tracking-wide text-(--color-muted)">Recommended Qualifications</h2>
            <p class="mt-2 text-sm leading-relaxed whitespace-pre-wrap"><%= job.recommendedQualifications %></p>
          </div>
        <% } %>
      </section>

      <section class="rounded-2xl border border-(--color-border) bg-white p-5 shadow-sm">
        <h2 class="text-sm font-medium uppercase tracking-wide text-(--color-muted)">Apply</h2>

        <% if (error) { %>
          <p class="mt-3 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></p>
        <% } %>

        <% if (!applicant) { %>
          <p class="mt-3 text-sm text-(--color-muted)">
            You need an applicant account to apply.
            <a href="/applicant/signup" class="font-medium text-(--color-accent)">Create account</a>
            or
            <a href="/applicant/login" class="font-medium text-(--color-accent)">sign in</a>.
          </p>
        <% } else { %>
          <form method="POST" action="/jobs/<%= job.id %>/apply" enctype="multipart/form-data" class="mt-4 grid gap-4">
            <p class="text-sm text-(--color-muted)">Signed in as <%= applicant.email %></p>

            <label class="space-y-1">
              <span class="block text-xs font-medium text-(--color-muted)">CV PDF (optional if you already uploaded one before)</span>
              <input name="cv" type="file" accept="application/pdf,.pdf" class="w-full rounded-xl border border-(--color-border) bg-white px-3 py-2 text-sm" />
            </label>

            <label class="space-y-1">
              <span class="block text-xs font-medium text-(--color-muted)">Notes (optional)</span>
              <textarea name="notes" rows="3" class="w-full rounded-xl border border-(--color-border) bg-white px-3 py-2 text-sm"></textarea>
            </label>

            <% if (job.questions.length) { %>
              <div class="grid gap-3">
                <h3 class="text-sm font-medium uppercase tracking-wide text-(--color-muted)">Additional Questions</h3>
                <% job.questions.forEach(function(question) { %>
                  <label class="space-y-1">
                    <span class="block text-xs font-medium text-(--color-muted)"><%= question.prompt %> <%= question.isRequired ? '*' : '' %></span>
                    <% if (question.inputType === 'textarea') { %>
                      <textarea name="question_<%= question.id %>" rows="3" class="w-full rounded-xl border border-(--color-border) bg-white px-3 py-2 text-sm"></textarea>
                    <% } else if (question.inputType === 'number') { %>
                      <input name="question_<%= question.id %>" type="number" class="w-full rounded-xl border border-(--color-border) bg-white px-3 py-2 text-sm" />
                    <% } else if (question.inputType === 'boolean') { %>
                      <select name="question_<%= question.id %>" class="w-full rounded-xl border border-(--color-border) bg-white px-3 py-2 text-sm">
                        <option value="">Select</option>
                        <option value="Yes">Yes</option>
                        <option value="No">No</option>
                      </select>
                    <% } else { %>
                      <input name="question_<%= question.id %>" type="text" class="w-full rounded-xl border border-(--color-border) bg-white px-3 py-2 text-sm" />
                    <% } %>
                  </label>
                <% }) %>
              </div>
            <% } %>

            <div>
              <button type="submit" class="inline-flex items-center rounded-xl bg-(--color-accent) px-4 py-2 text-sm font-medium text-white">Submit Application</button>
            </div>
          </form>
        <% } %>
      </section>
    </main>
  </body>
</html>
