<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <link rel="stylesheet" href="/assets/css/style.css" />
    <script type="module" src="/kanban.js"></script>
  </head>
  <body class="min-h-screen bg-(--color-bg) text-(--color-text) antialiased">
    <header class="mx-auto w-full px-4 py-6 sm:px-6 sm:py-10">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="min-w-0">
          <a href="/" class="text-sm text-(--color-accent)">← Back to candidate directory</a>
          <h1 class="mt-2 text-2xl font-semibold tracking-tight sm:text-3xl">Candidate Status Board</h1>
          <p class="mt-2 max-w-2xl text-xs text-(--color-muted) sm:text-sm"><%= companyName %> · Drag cards between columns to update status</p>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <% if (user.role === 'admin') { %>
            <a href="/admin/users" class="text-sm text-(--color-accent)">Users</a>
          <% } %>
          <span class="text-sm text-(--color-muted)"><%= user.username %></span>
          <span class="rounded-full px-2 py-0.5 text-xs font-medium <%- user.role === 'admin' ? 'bg-violet-100 text-violet-700' : 'bg-sky-100 text-sky-700' %>"><%= user.role %></span>
          <form method="POST" action="/logout">
            <button type="submit" class="rounded-xl border border-(--color-border) px-3 py-1.5 text-sm font-medium text-(--color-muted) hover:bg-gray-50">Sign out</button>
          </form>
          <a
            href="/applicants/new"
            class="inline-flex items-center justify-center rounded-xl bg-(--color-accent) px-4 py-2 text-sm font-medium text-white"
          >
            Add New Applicant
          </a>
        </div>
      </div>
    </header>

    <main class="w-full px-4 pb-10 sm:px-6 sm:pb-12" aria-live="polite">
      <p id="kanban-loading" class="text-sm text-(--color-muted)">Loading candidates...</p>
      <p id="kanban-error" class="hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></p>
      <div
        id="kanban-empty"
        class="hidden rounded-xl border border-(--color-border) bg-white px-4 py-6 text-sm text-(--color-muted)"
      >
        No candidates found.
      </div>

      <section
        id="kanban-columns"
        class="mt-5 flex flex-col gap-3 sm:gap-4 lg:mt-6 lg:flex-row lg:overflow-x-auto lg:pb-3"
        data-statuses='<%- JSON.stringify(applicationStatuses) %>'
        aria-label="Candidate status columns"
      ></section>
    </main>
  </body>
</html>
